# mktg environment variables
#
# Copy this file to `.env` and fill in the values you need.
# All variables below are OPTIONAL — mktg works at zero config with
# progressive enhancement. Set these only for the integrations you use.
#
# The `.env` file is gitignored; this `.env.example` file is committed.
# Verify with `mktg doctor --json` which integrations are wired up.

# ============================================================================
# Integration API keys (per-skill)
# ============================================================================

# Typefully API key — used by the `typefully` skill and `mktg publish --adapter typefully`
# for scheduling social posts (X/Twitter, LinkedIn, Threads, Bluesky).
# Get yours at: https://typefully.com/settings/integrations
TYPEFULLY_API_KEY=

# Resend API key — used by the `send-email`, `resend-inbound`, and
# `agent-email-inbox` skills plus `mktg publish --adapter resend` for
# transactional email sending and inbound email webhook processing.
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=

# Resend webhook secret — used by the `resend-inbound` and `agent-email-inbox`
# skills to verify the HMAC signature on inbound-email webhooks from Resend.
# Required only if you're consuming inbound email (not for outbound send).
# Get yours at: https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=

# Gemini API key — used by the `image-gen` skill to generate images via
# the Google Gemini API (model: gemini-3.1-flash-image-preview). Required
# for any `/image-gen`, `/creative`, or `/paper-marketing` image generation.
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ============================================================================
# CLI behavior overrides (optional)
# ============================================================================

# Force machine-readable JSON output even in a TTY context.
# mktg already auto-switches to JSON when stdout is piped (non-TTY), so
# setting this is only needed for agents that want JSON while keeping a
# terminal attached. Values: `json` (forces JSON). Leave unset for default.
# OUTPUT_FORMAT=json

# Disable ANSI color codes in terminal output. Standard no-color convention
# (https://no-color.org). Set to any non-empty value to disable colors.
# NO_COLOR=1

# ============================================================================
# Typefully script overrides (advanced — rarely needed)
# ============================================================================

# Override the Typefully API base URL. Defaults to https://api.typefully.com/v2.
# Only set this if you're testing against a staging environment.
# TYPEFULLY_API_BASE=https://api.typefully.com/v2

# Override the poll interval (in milliseconds) when waiting for Typefully media
# upload processing. Used by skills/typefully/scripts/typefully.js.
# TYPEFULLY_MEDIA_POLL_INTERVAL_MS=2000
