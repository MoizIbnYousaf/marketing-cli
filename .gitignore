# prepack/postpack lifecycle: temporary backup of package.json while npm packs
# the tarball without the `workspaces` field. Restored automatically by
# scripts/postpack-restore.cjs. Should never be committed.
package.json.prepack-backup

# launch / local marketing scratch (not for public repo)
marketing/

# Public-readiness audit artifacts (local-only)
docs/PUBLIC-READINESS-*.md

# Working drafts: launch copy, verification reports, anything pre-publish.
# Already-tracked files inside _drafts/ stay tracked; this just keeps fresh
# notes and reports out of git status until someone deliberately adds them.
_drafts/

# Launch video drafts (large, distributed via tweets/site, not the repo)
brand/assets/launch-video-v2*.mp4

